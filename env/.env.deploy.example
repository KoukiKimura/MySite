# ==============================================================
# デプロイ用環境変数テンプレート
# このファイルをコピーして .env.deploy として保存し、値を記入してください。
# .env.deploy は git 管理対象外です。このファイル (.example) のみ管理します。
# ==============================================================

# FTP サーバーホスト名（ConoHa Wing コントロールパネル → FTP で確認）
DEPLOY_FTP_HOST=

# FTP ユーザー名（例: root@example.com）
DEPLOY_FTP_USER=

# FTP パスワード
DEPLOY_FTP_PASSWORD=

# FTP ポート（省略時: 21）
DEPLOY_FTP_PORT=21

# アップロード先リモートディレクトリ（例: /public_html/example.com）
DEPLOY_REMOTE_DIR=

# デプロイ完了時に表示するサイト URL（例: https://example.com）
DEPLOY_SITE_URL=
