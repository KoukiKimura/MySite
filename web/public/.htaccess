# ==========================================================================
#  ペンギンげーむず！ Apache 設定
#  ConoHa Wing (Apache) 用 .htaccess
# ==========================================================================

# ---- 文字コード ----
AddDefaultCharset UTF-8

# ---- MIME タイプ ----
<IfModule mod_mime.c>
  AddType application/javascript          .js .mjs
  AddType text/css                        .css
  AddType image/svg+xml                   .svg .svgz
  AddType image/x-icon                    .ico
  AddType application/manifest+json       .webmanifest
  AddType font/woff2                      .woff2
  AddType font/woff                       .woff
</IfModule>

# ---- gzip 圧縮 ----
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json image/svg+xml font/woff2 font/woff
</IfModule>

# ---- キャッシュ制御 ----
<IfModule mod_expires.c>
  ExpiresActive On
  # ハッシュ付きアセット（Vite ビルド生成物）は1年キャッシュ
  <FilesMatch "\.[0-9a-f]{8}\.(js|css|woff2?|png|jpg|svg|ico)$">
    ExpiresDefault "access plus 1 year"
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  # index.html はキャッシュしない（常に最新を取得）
  <FilesMatch "^index\.html$">
    ExpiresDefault "access plus 0 seconds"
    Header set Cache-Control "no-cache, no-store, must-revalidate"
  </FilesMatch>
  # JSONデータは短めにキャッシュ
  <FilesMatch "\.json$">
    ExpiresDefault "access plus 1 hour"
    Header set Cache-Control "public, max-age=3600"
  </FilesMatch>
</IfModule>

# ---- セキュリティヘッダー ----
<IfModule mod_headers.c>
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Permissions-Policy "camera=(), microphone=(), geolocation=()"
  # HTTPS 強制（Let's Encrypt 有効済み）
  Header always set Strict-Transport-Security "max-age=63072000; includeSubDomains"
</IfModule>

# ---- HTTPS リダイレクト & www → non-www ----
# ConoHa Wing はロードバランサー経由のため %{HTTPS} ではなく
# X-Forwarded-Proto ヘッダーで判定する
<IfModule mod_rewrite.c>
  RewriteEngine On

  # HTTP → HTTPS（プロキシ越しの判定）
  RewriteCond %{HTTP:X-Forwarded-Proto} =http [NC]
  RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]

  # www → non-www
  RewriteCond %{HTTP_HOST} ^www\.pengin24\.com$ [NC]
  RewriteRule ^ https://pengin24.com%{REQUEST_URI} [R=301,L]
</IfModule>

# ---- 不要ファイルへのアクセス拒否 ----
<FilesMatch "(^\.htaccess|\.env|package\.json|vite\.config\.js)$">
  Require all denied
</FilesMatch>
